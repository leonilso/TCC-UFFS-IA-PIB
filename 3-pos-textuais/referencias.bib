@article{Silva_Clericuzi_Carvalho_2025, title={MODELAGEM DE SÉRIES TEMPORAIS UTILIZANDO ARIMA: PREVISÃO FUTURA DO PIB BRASILEIRO}, volume={6}, url={https://icmreview.com/icmr/article/view/385}, DOI={10.54033/icmrv6n2-045}, abstractNote={&amp;lt;p&amp;gt;O Produto Interno Bruto (PIB) de um país representa a soma de todos os bens e serviços finais produzidos em seu território durante um intervalo temporal específico, posicionando-se como um indicador macroeconômico primordial para avaliar o desempenho econômico agregado. A evolução do PIB oferece subsídios fundamentais para a formulação de políticas econômicas, visto que sua previsão reduz as incertezas associadas ao ambiente econômico e permite a antecipação de tendências por parte dos tomadores de decisão. Neste estudo, foi empregada a metodologia Box-Jenkins, por meio da utilização de modelos auto-regressivos integrados de médias móveis (ARIMA), para a modelagem e previsão do PIB brasileiro. O processo metodológico contemplou as etapas de tratamento e limpeza dos dados, identificação da estrutura de dependência temporal, estimação dos parâmetros e validação do modelo ajustado. As projeções realizadas para o período de 2025 a 2029 indicam um cenário de estabilidade acompanhado de um leve crescimento do PIB nacional. O modelo ARIMA apresentou performance satisfatória para a previsão em curto prazo, reafirmando sua adequação e aplicabilidade na análise de séries temporais de indicadores macroeconômicos.&amp;lt;/p&amp;gt;}, number={2}, journal={International Contemporary Management Review}, author={Silva, Thiago Raimundo da and Clericuzi, Adriana Zenaide and Carvalho, Joelson Nogueira de}, year={2025}, month={Aug.}, pages={e385} }

